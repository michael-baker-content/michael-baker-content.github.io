---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`404 — ${SITE_TITLE}`} description="Page not found." />
  </head>
  <body>
    <Header />
    <main>
      <div class="not-found">
        <p class="code">404</p>
        <h1>Page not found</h1>
        <p class="message">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="links">
          <a href="/" class="home-btn">Go home</a>
          <a href="/blog" class="blog-link">Browse posts →</a>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .not-found {
    padding: 6em 0 4em;
    text-align: center;
  }
  .code {
    font-size: 6em;
    font-weight: 500;
    color: var(--accent);
    line-height: 1;
    margin: 0 0 0.25em;
  }
  h1 {
    font-size: 1.5em;
    margin: 0 0 0.5em;
    color: var(--text);
  }
  .message {
    color: var(--text-muted);
    font-size: 0.95em;
    margin: 0 0 2em;
  }
  .links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5em;
  }
  .home-btn {
    background: var(--accent);
    color: var(--bg);
    padding: 0.5em 1.25em;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.9em;
    font-weight: 500;
  }
  .home-btn:hover {
    background: var(--bg);
    color: var(--accent);
    outline: 1px solid var(--accent);
  }
  .blog-link {
    font-size: 0.9em;
    color: var(--accent);
    text-decoration: none;
  }
  .blog-link:hover {
    color: var(--accent-dark);
  }
</style>
