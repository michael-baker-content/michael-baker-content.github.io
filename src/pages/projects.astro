---
import { ClientRouter } from "astro:transitions";
import BaseHead from "../components/BaseHead.astro";
import CloudinaryImage from "../components/CloudinaryImage.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
import { projects } from "../data/projects";

const statusLabel = {
  active: "Active",
  complete: "Complete",
  learning: "Learning",
};

const statusColors = {
  active: "status-active",
  complete: "status-complete",
  learning: "status-learning",
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Projects — ${SITE_TITLE}`}
      description="A portfolio of projects I have been working on."
    />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main>
      <h1 class="page-title">Projects</h1>
      <div class="projects-grid">
        {
          projects.map((project) => (
            <div class="project-card">
              <div class="project-image">
                {project.image ? (
                  <CloudinaryImage
                    publicId={project.image}
                    alt={project.name}
                    width={600}
                    height={300}
                    bare={true}
                  />
                ) : (
                  <div class="placeholder-image">
                    <span>{project.name[0]}</span>
                  </div>
                )}
              </div>
              <div class="project-body">
                <div class="project-header">
                  <h2 class="project-name">
                    <a href={`/projects/${project.slug}`}>{project.name}</a>
                  </h2>
                  <span class={`status-badge ${statusColors[project.status]}`}>
                    {statusLabel[project.status]}
                  </span>
                </div>
                {project.type && (
                  <p class="project-type">{project.type.replace("-", " ")}</p>
                )}
                <p class="project-desc">{project.description}</p>
                {project.learningFocus && (
                  <p class="learning-focus">
                    <span class="learning-label">Focus:</span>{" "}
                    {project.learningFocus}
                  </p>
                )}
                <div class="project-tags">
                  {project.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <div class="project-links">
                  <a href={`/projects/${project.slug}`} class="btn btn-primary">
                    View project
                  </a>

                  <a
                    href={project.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-secondary"
                  >
                    <svg
                      viewBox="0 0 16 16"
                      width="14"
                      height="14"
                      aria-hidden="true"
                    >
                      <path
                        fill="currentColor"
                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                      />
                    </svg>
                    Repo
                  </a>
                  {project.liveUrl && (
                    <a
                      href={project.liveUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-secondary"
                    >
                      ↗ Live
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    background: var(--projects-bg);
    padding-bottom: 2em;
  }
  .page-title {
    font-size: 0.85em;
    color: var(--text-muted);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5em;
    font-family: var(--font-syne);
  }

  .projects-grid {
    columns: 2;
    column-gap: 1.5em;
  }
  .project-card {
    background: var(--bg-surface);
    border: 0.5px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    break-inside: avoid;
    margin-bottom: 1.5em;
  }
  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: var(--box-shadow);
  }
  .project-image {
    width: 100%;
    aspect-ratio: 2 / 1;
    overflow: hidden;
    background: var(--bg-subtle);
  }
  .project-image :global(figure) {
    margin: 0;
    height: 100%;
  }
  .project-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    border: none;
    display: block;
  }
  .placeholder-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-subtle);
    font-size: 3em;
    font-weight: 500;
    color: var(--accent);
  }
  .project-body {
    padding: 1.25em;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    flex: 1;
  }
  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5em;
  }
  .project-name {
    font-size: 1.1em;
    font-weight: 500;
    margin: 0;
    line-height: 1.3;
  }
  .project-name a {
    color: var(--text);
    text-decoration: none;
  }
  .project-name a:hover {
    color: var(--accent);
  }
  .status-badge {
    font-size: 0.7em;
    padding: 2px 8px;
    border-radius: 999px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .status-active {
    background: rgba(163, 230, 53, 0.15);
    color: var(--accent);
    border: 0.5px solid var(--accent);
  }
  .status-complete {
    background: var(--bg-subtle);
    color: var(--text-muted);
    border: 0.5px solid var(--border);
  }
  .status-learning {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    border: 0.5px solid rgba(59, 130, 246, 0.3);
  }
  .project-type {
    font-size: 0.75em;
    color: var(--text-muted);
    text-transform: capitalize;
    margin: 0;
  }
  .project-desc {
    font-size: 0.875em;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .learning-focus {
    font-size: 0.8em;
    color: var(--text-muted);
    margin: 0;
  }
  .learning-label {
    color: var(--accent);
    font-weight: 500;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
    margin-top: 0.25em;
  }
  .tag {
    background: var(--bg-subtle);
    color: var(--text-muted);
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 0.75em;
    border: 0.5px solid var(--border);
  }
  .project-links {
    display: flex;
    gap: 0.5em;
    margin-top: auto;
    padding-top: 0.75em;
    flex-wrap: nowrap;
    align-items: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.8em;
    padding: 0.35em 0.85em;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 0.15s,
      color 0.15s,
      border-color 0.15s;
    border: 1px solid transparent;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    font-weight: 500;
  }
  .btn-primary:hover {
    background: var(--bg);
    color: var(--accent);
    border-color: var(--accent);
  }
  .btn-secondary {
    background: var(--bg);
    color: var(--text-muted);
    border-color: var(--border);
  }
  .btn-secondary:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  @media (max-width: 600px) {
    .projects-grid {
      columns: 1;
    }
  }
</style>
