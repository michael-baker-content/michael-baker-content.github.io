---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>michael-baker-content</h1>
        <p class="tagline">
          In-depth writing about code, creative tools, and projects in progress.
        </p>
        <a href="/blog" class="browse-btn">Browse all posts</a>
      </section>

      <section class="recent">
        <h2>Recent posts</h2>
        <ul class="post-list">
          {
            posts.map((post) => (
              <li class="post-card">
                <div class="post-meta">
                  <FormattedDate date={post.data.pubDate} />
                  {post.data.tags && post.data.tags.length > 0 && (
                    <span class="tag-preview">{post.data.tags[0]}</span>
                  )}
                </div>
                <h3 class="post-title">
                  <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                </h3>
                <p class="post-desc">{post.data.description}</p>
              </li>
            ))
          }
        </ul>
        <a href="/blog" class="all-posts-link">All posts →</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    background: var(--hero-bg);
    margin: -3em -1em 3em -1em;
    padding: 4em 1em 3em;
  }

  @media (max-width: 720px) {
    .hero {
      margin: -1em -1em 2em -1em;
      padding: 2.5em 1em 2em;
    }
  }

  .hero h1 {
    font-size: 2.5em;
    margin-bottom: 0.4em;
    color: var(--text);
  }
  .tagline {
    font-size: 1.1em;
    color: var(--text-muted);
    margin-bottom: 1.5em;
  }
  .browse-btn {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    padding: 0.5em 1.25em;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.9em;
    font-weight: 500;
  }
  .browse-btn:hover {
    background: var(--accent-dark);
    color: var(--bg);
  }
  .recent h2 {
    font-size: 0.85em;
    color: var(--text-muted);
    font-weight: 400;
    margin-bottom: 1.5em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2em;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .post-card {
    border-top: 0.5px solid var(--border);
    padding: 1.5em 0;
  }
  .post-list li:last-child {
    border-bottom: 0.5px solid var(--border);
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75em;
    font-size: 0.8em;
    color: var(--text-muted);
    margin-bottom: 0.5em;
  }
  .tag-preview {
    background: var(--bg-subtle);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.9em;
  }
  .post-title {
    margin: 0 0 0.5em;
    line-height: 1.3;
  }
  .post-title a {
    color: var(--text);
    text-decoration: none;
    font-size: 1.1em;
  }
  .post-title a:hover {
    color: var(--accent);
  }
  .post-desc {
    font-size: 0.85em;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .all-posts-link {
    font-size: 0.9em;
    color: var(--accent);
    text-decoration: none;
  }
  .all-posts-link:hover {
    color: var(--accent-dark);
  }
</style>
