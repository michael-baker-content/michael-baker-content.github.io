---
import { ClientRouter } from "astro:transitions";
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { projects } from "../data/projects";

const featuredProjects = projects.filter((p) => p.featured);
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = allPosts.find((p) => p.data.featured);
const recentPosts = allPosts
  .filter((p) => p.id !== featuredPost?.id)
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div class="hero-canvas" id="hero-canvas"></div>
        <div class="hero-content">
          <h1>Michael Baker</h1>
          <p class="tagline">
            In-depth writing about code, creative tools, and projects in
            progress.
          </p>
          <a href="/blog" class="browse-btn">Browse all posts</a>
        </div>
      </section>

      {
        featuredProjects.length > 0 && (
          <section class="projects-section">
            <h2>Projects</h2>
            <div class="projects-grid">
              {featuredProjects.map((project) => (
                <a href={`/projects/${project.slug}`} class="project-card">
                  <div class="project-info">
                    <span class="project-name">{project.name}</span>
                    {project.type && (
                      <span class="project-type">
                        {project.type.replace("-", " ")}
                      </span>
                    )}
                  </div>
                  <p class="project-desc">{project.description}</p>
                  <div class="project-tags">
                    {project.tags.slice(0, 3).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </a>
              ))}
            </div>
            <a href="/projects" class="all-projects-link">
              All projects →
            </a>
          </section>
        )
      }
      <div class="posts-section">
        {
          featuredPost && (
            <section class="featured">
              <div class="featured-canvas" id="featured-canvas" />
              <div class="featured-content">
                <h2>Featured Post</h2>
                <div class="featured-card">
                  <div class="post-meta">
                    <FormattedDate date={featuredPost.data.pubDate} />
                    {featuredPost.data.tags &&
                      featuredPost.data.tags.length > 0 && (
                        <span class="tag-preview">
                          {featuredPost.data.tags[0]}
                        </span>
                      )}
                  </div>
                  <h3 class="post-title">
                    <a href={`/blog/${featuredPost.id}/`}>
                      {featuredPost.data.title}
                    </a>
                  </h3>
                  <p class="post-desc">{featuredPost.data.description}</p>
                </div>
              </div>
            </section>
          )
        }

        <section class="recent">
          <h2>Recent Posts</h2>
          <ul class="post-list">
            {
              recentPosts.map((post) => (
                <li class="post-card">
                  <div class="post-meta">
                    <FormattedDate date={post.data.pubDate} />
                    {post.data.tags && post.data.tags.length > 0 && (
                      <span class="tag-preview">{post.data.tags[0]}</span>
                    )}
                  </div>
                  <h3 class="post-title">
                    <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                  </h3>
                  <p class="post-desc">{post.data.description}</p>
                </li>
              ))
            }
          </ul>
          <a href="/blog" class="all-posts-link">All posts →</a>
        </section>
      </div>

      <Footer />
    </main>
  </body>
</html>

<style>
  main {
    padding: 0;
  }
  .hero {
    position: relative;
    background: var(--hero-bg);
    margin: 0;
    padding: 4em 1em 3em;
    overflow: hidden;
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-canvas canvas {
    display: block;
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  @media (max-width: 768px) {
    .hero-canvas {
      display: none;
    }
  }
  @media (max-width: 720px) {
    .hero {
      padding: 2.5em 1em 2em;
    }
  }

  .hero h1 {
    font-size: 2.5em;
    margin-bottom: 0.4em;
    color: var(--text);
  }

  .recent {
    padding: 0 1em;
  }

  .recent h2,
  .featured h2,
  .projects-section h2 {
    font-size: 0.85em;
    color: var(--text-muted);
    font-weight: 400;
    margin-bottom: 1.5em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-syne);
  }

  .tagline {
    font-size: 1.1em;
    color: var(--text-muted);
    margin-bottom: 1.5em;
  }

  .browse-btn {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    padding: 0.5em 1.25em;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.9em;
    font-weight: 500;
    border: 1px solid transparent;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }
  .browse-btn:hover {
    background: var(--bg);
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2em;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .post-card {
    border-top: 0.5px solid var(--border);
    padding: 1.5em 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75em;
    font-size: 0.8em;
    color: var(--text-muted);
    margin-bottom: 0.5em;
  }
  .tag-preview {
    background: var(--bg-subtle);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.9em;
  }
  .post-title {
    margin: 0 0 0.5em;
    line-height: 1.3;
  }
  .post-title a {
    color: var(--text);
    text-decoration: none;
    font-size: 0.95em;
  }
  .post-title a:hover {
    color: var(--accent);
  }
  .post-desc {
    font-size: 0.85em;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .all-posts-link {
    font-size: 0.9em;
    color: var(--accent);
    text-decoration: none;
  }
  .all-posts-link:hover {
    color: var(--accent-dark);
  }
  .featured {
    position: relative;
    margin-top: 0;
    padding-top: 2em;
    overflow: hidden;
  }
  .featured-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 1;
  }
  .featured-canvas canvas {
    display: block;
  }
  .featured-content {
    position: relative;
    z-index: 1;
  }
  @media (max-width: 768px) {
    .featured-canvas {
      display: none;
    }
  }
  .featured h2 {
    font-size: 0.85em;
    color: var(--text-muted);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5em;
  }

  .featured-card {
    border: 0.5px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 1.25em 1.5em;
    margin-bottom: 3em;
    background: var(--bg-surface);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
    cursor: pointer;
  }
  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--box-shadow);
    border-color: var(--accent);
    border-left-color: var(--accent);
  }

  .featured-card .post-title a {
    color: var(--text);
    text-decoration: none;
    font-size: 1em;
    transition: color 0.2s ease;
  }
  .featured-card:hover .post-title a {
    color: var(--accent);
  }
  .featured-card .post-title a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }

  .projects-section {
    background: var(--projects-bg);
    padding: 2em 1em;
  }

  .projects-grid {
    columns: 3;
    column-gap: 1em;
    margin-bottom: 1em;
  }
  .project-card {
    background: var(--bg-surface);
    border: 0.5px solid var(--border);
    border-radius: 8px;
    padding: 1em;
    text-decoration: none;
    color: var(--text);
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    break-inside: avoid;
    margin-bottom: 1em;
  }
  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: var(--box-shadow);
  }

  @media (max-width: 720px) {
    .projects-grid {
      columns: 1;
    }
  }

  .project-info {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5em;
  }
  .project-name {
    font-size: 0.95em;
    font-weight: 500;
    color: var(--text);
  }
  .project-type {
    font-size: 0.7em;
    color: var(--text-muted);
    text-transform: capitalize;
  }
  .project-desc {
    font-size: 0.8em;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
    margin-top: auto;
  }
  .tag {
    background: var(--bg-subtle);
    color: var(--text-muted);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.72em;
  }
  .all-projects-link {
    font-size: 0.9em;
    color: var(--accent);
    text-decoration: none;
  }
  .all-projects-link:hover {
    color: var(--accent-dark);
  }
  .posts-section {
    background: var(--posts-bg);
    padding: 0 1em 2em;
  }
</style>
<script>
  declare global {
    interface Window {
      p5: any;
    }
  }

  async function initHeroSketch() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    if (window.innerWidth < 768) return;

    const container = document.getElementById("hero-canvas");
    if (!container) return;

    if (!window.p5) {
      await new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src =
          "https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js";
        script.onload = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
      });
    }

    if ((container as any)._p5instance) {
      (container as any)._p5instance.remove();
      (container as any)._p5instance = null;
    }

    const sketchFn = (p: any) => {
      let shapes: any[] = [];

      function getColors() {
        const isDark =
          document.documentElement.getAttribute("data-theme") === "dark" ||
          (!document.documentElement.getAttribute("data-theme") &&
            window.matchMedia("(prefers-color-scheme: dark)").matches);
        return isDark
          ? { fill: [80, 140, 40, 18], stroke: [120, 180, 60, 55] }
          : { fill: [160, 200, 100, 25], stroke: [80, 140, 40, 70] };
      }

      class Shape {
        x!: number;
        y!: number;
        size!: number;
        speedX!: number;
        speedY!: number;
        rotation!: number;
        rotationSpeed!: number;
        sides!: number;
        noiseOffset!: number;
        constructor() {
          this.reset(true);
        }
        reset(randomY = false) {
          this.x = p.random(p.width);
          this.y = randomY ? p.random(p.height) : p.random(-100, -20);
          this.size = p.random(40, 120);
          this.speedX = p.random(-0.15, 0.15);
          this.speedY = p.random(0.1, 0.35);
          this.rotation = p.random(p.TWO_PI);
          this.rotationSpeed = p.random(-0.003, 0.003);
          this.sides = Math.floor(p.random(3, 7));
          this.noiseOffset = p.random(1000);
        }
        update() {
          this.x += this.speedX + (p.noise(this.noiseOffset) - 0.5) * 0.3;
          this.y += this.speedY;
          this.rotation += this.rotationSpeed;
          this.noiseOffset += 0.005;
          if (this.y > p.height + 100) this.reset();
        }
        draw(colors: any) {
          p.push();
          p.translate(this.x, this.y);
          p.rotate(this.rotation);
          p.fill(...colors.fill);
          p.stroke(...colors.stroke);
          p.strokeWeight(1);
          p.beginShape();
          for (let i = 0; i < this.sides; i++) {
            const angle = (p.TWO_PI / this.sides) * i;
            p.vertex(
              Math.cos(angle) * this.size * 0.5,
              Math.sin(angle) * this.size * 0.5,
            );
          }
          p.endShape(p.CLOSE);
          p.pop();
        }
      }

      p.setup = function () {
        const container = p.canvas.parentElement;
        p.createCanvas(container.offsetWidth, container.offsetHeight);
      };

      p.draw = function () {
        const colors = getColors();
        p.clear();
        if (shapes.length === 0) {
          for (let i = 0; i < 18; i++) shapes.push(new Shape());
        }
        shapes.forEach((s: Shape) => {
          s.update();
          s.draw(colors);
        });
      };

      p.windowResized = function () {
        const container = p.canvas.parentElement;
        p.resizeCanvas(container.offsetWidth, container.offsetHeight);
      };
    };

    (container as any)._p5instance = new window.p5(sketchFn, container);
  }

  async function initFeaturedSketch() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    if (window.innerWidth < 768) return;

    const container = document.getElementById("featured-canvas");
    if (!container) return;

    if (!window.p5) {
      await new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src =
          "https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js";
        script.onload = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
      });
    }

    if ((container as any)._p5instance) {
      (container as any)._p5instance.remove();
      (container as any)._p5instance = null;
    }

    const sketchFn = (p: any) => {
      let threads: any[] = [];

      function getColors() {
        const isDark =
          document.documentElement.getAttribute("data-theme") === "dark" ||
          (!document.documentElement.getAttribute("data-theme") &&
            window.matchMedia("(prefers-color-scheme: dark)").matches);
        return isDark
          ? { stroke: [120, 180, 60, 30] }
          : { stroke: [80, 140, 40, 40] };
      }

      class Thread {
        x!: number;
        y!: number;
        length!: number;
        angle!: number;
        speedX!: number;
        speedY!: number;
        noiseOffset!: number;
        weight!: number;

        constructor() {
          this.reset(true);
        }

        reset(randomPos = false) {
          this.x = p.random(p.width);
          this.y = randomPos ? p.random(p.height) : p.random(-50, -10);
          this.length = p.random(100, 250);
          this.angle = p.random(p.TWO_PI);
          this.speedX = p.random(-0.2, 0.2);
          this.speedY = p.random(0.15, 0.4);
          this.noiseOffset = p.random(1000);
          this.weight = p.random(1, 2.5);
        }

        update() {
          this.x += this.speedX + (p.noise(this.noiseOffset) - 0.5) * 0.4;
          this.y += this.speedY;
          this.angle += (p.noise(this.noiseOffset + 500) - 0.5) * 0.02;
          this.noiseOffset += 0.004;
          if (this.y > p.height + 100) this.reset();
        }

        draw(colors: any) {
          p.push();
          p.translate(this.x, this.y);
          p.rotate(this.angle);
          p.stroke(...colors.stroke);
          p.strokeWeight(this.weight);
          p.noFill();
          p.beginShape();
          for (let i = 0; i < this.length; i += 5) {
            const nx = p.noise(this.noiseOffset + i * 0.05) * 8 - 4;
            p.curveVertex(nx, i - this.length / 2);
          }
          p.endShape();
          p.pop();
        }
      }

      p.setup = function () {
        const cont = p.canvas.parentElement;
        p.createCanvas(cont.offsetWidth, cont.offsetHeight);
        for (let i = 0; i < 40; i++) threads.push(new Thread());
      };

      p.draw = function () {
        const colors = getColors();
        p.clear();
        threads.forEach((t: Thread) => {
          t.update();
          t.draw(colors);
        });
      };

      p.windowResized = function () {
        const cont = p.canvas.parentElement;
        p.resizeCanvas(cont.offsetWidth, cont.offsetHeight);
      };
    };

    (container as any)._p5instance = new window.p5(sketchFn, container);
  }

  initHeroSketch();
  initFeaturedSketch();
  document.addEventListener("astro:after-swap", () => {
    initHeroSketch();
    initFeaturedSketch();
  });
</script>
