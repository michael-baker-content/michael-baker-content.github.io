---
import { ClientRouter } from "astro:transitions";
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { projects } from "../data/projects";
const featuredProjects = projects.filter((p) => p.featured);
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = allPosts.find((p) => p.data.featured);
const recentPosts = allPosts
  .filter((p) => p.id !== featuredPost?.id)
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>Michael Baker</h1>
        <p class="tagline">
          In-depth writing about code, creative tools, and projects in progress.
        </p>
        <a href="/blog" class="browse-btn">Browse all posts</a>
      </section>
      {
        featuredProjects.length > 0 && (
          <section class="projects-section">
            <h2>Projects</h2>
            <div class="projects-grid">
              {featuredProjects.map((project) => (
                <a href="/projects" class="project-card">
                  <div class="project-info">
                    <span class="project-name">{project.name}</span>
                    {project.type && (
                      <span class="project-type">
                        {project.type.replace("-", " ")}
                      </span>
                    )}
                  </div>
                  <p class="project-desc">{project.description}</p>
                  <div class="project-tags">
                    {project.tags.slice(0, 3).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </a>
              ))}
            </div>
            <a href="/projects" class="all-projects-link">
              All projects →
            </a>
          </section>
        )
      }
      <div class="posts-section">
        {
          featuredPost && (
            <section class="featured">
              <h2>Featured Post</h2>
              <div class="featured-card">
                <div class="post-meta">
                  <FormattedDate date={featuredPost.data.pubDate} />
                  {featuredPost.data.tags &&
                    featuredPost.data.tags.length > 0 && (
                      <span class="tag-preview">
                        {featuredPost.data.tags[0]}
                      </span>
                    )}
                </div>
                <h3 class="post-title">
                  <a href={`/blog/${featuredPost.id}/`}>
                    {featuredPost.data.title}
                  </a>
                </h3>
                <p class="post-desc">{featuredPost.data.description}</p>
              </div>
            </section>
          )
        }

        <section class="recent">
          <h2>Recent Posts</h2>
          <ul class="post-list">
            {
              recentPosts.map((post) => (
                <li class="post-card">
                  <div class="post-meta">
                    <FormattedDate date={post.data.pubDate} />
                    {post.data.tags && post.data.tags.length > 0 && (
                      <span class="tag-preview">{post.data.tags[0]}</span>
                    )}
                  </div>
                  <h3 class="post-title">
                    <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                  </h3>
                  <p class="post-desc">{post.data.description}</p>
                </li>
              ))
            }
          </ul>
          <a href="/blog" class="all-posts-link">All posts →</a>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    padding-top: 0;
    padding-bottom: 0;
  }
  .hero {
    background: var(--hero-bg);
    margin: 0 -1em 0 -1em;
    padding: 4em 1em 3em;
  }

  @media (max-width: 720px) {
    .hero {
      margin: 0 -1em 0 -1em;
      padding: 2.5em 1em 2em;
    }
  }

  .hero h1 {
    font-size: 2.5em;
    margin-bottom: 0.4em;
    color: var(--text);
  }
  .tagline {
    font-size: 1.1em;
    color: var(--text-muted);
    margin-bottom: 1.5em;
  }
  .browse-btn {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    padding: 0.5em 1.25em;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.9em;
    font-weight: 500;
  }
  .browse-btn:hover {
    background: var(--accent-dark);
    color: var(--bg);
  }
  .recent h2 {
    font-size: 0.85em;
    color: var(--text-muted);
    font-weight: 400;
    margin-bottom: 1.5em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2em;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .post-card {
    border-top: 0.5px solid var(--border);
    padding: 1.5em 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75em;
    font-size: 0.8em;
    color: var(--text-muted);
    margin-bottom: 0.5em;
  }
  .tag-preview {
    background: var(--bg-subtle);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.9em;
  }
  .post-title {
    margin: 0 0 0.5em;
    line-height: 1.3;
  }
  .post-title a {
    color: var(--text);
    text-decoration: none;
    font-size: 1.1em;
  }
  .post-title a:hover {
    color: var(--accent);
  }
  .post-desc {
    font-size: 0.85em;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .all-posts-link {
    font-size: 0.9em;
    color: var(--accent);
    text-decoration: none;
  }
  .all-posts-link:hover {
    color: var(--accent-dark);
  }
  .featured {
    margin-top: 0;
    padding-top: 2em;
  }
  .featured h2 {
    font-size: 0.85em;
    color: var(--text-muted);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5em;
  }
  .featured-card {
    border: 0.5px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 1.25em 1.5em;
    margin-bottom: 3em;
    background: var(--bg-surface);
  }
  .featured-card .post-title a {
    font-size: 1.2em;
    color: var(--text);
    text-decoration: none;
  }
  .featured-card .post-title a:hover {
    color: var(--accent);
  }
  .projects-section {
    background: var(--projects-bg);
    margin: 0 -1em 0 -1em;
    padding: 2em 1em;
  }
  .projects-section h2 {
    font-size: 0.85em;
    color: var(--text-muted);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.25em;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1em;
    margin-bottom: 1em;
    align-items: start;
  }
  .project-card:nth-child(2n) {
    margin-top: 1.5em;
  }
  .project-card {
    background: var(--bg-surface);
    border: 0.5px solid var(--border);
    border-radius: 8px;
    padding: 1em;
    text-decoration: none;
    color: var(--text);
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }
  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: var(--box-shadow);
  }
  .project-info {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5em;
  }
  .project-name {
    font-size: 0.95em;
    font-weight: 500;
    color: var(--text);
  }
  .project-type {
    font-size: 0.7em;
    color: var(--text-muted);
    text-transform: capitalize;
  }
  .project-desc {
    font-size: 0.8em;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
    margin-top: auto;
  }
  .tag {
    background: var(--bg-subtle);
    color: var(--text-muted);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.72em;
  }
  .all-projects-link {
    font-size: 0.9em;
    color: var(--accent);
    text-decoration: none;
  }
  .all-projects-link:hover {
    color: var(--accent-dark);
  }
  .posts-section {
    background: var(--posts-bg);
    margin: 0 -1em 0 -1em;
    padding: 0 1em 2em;
  }
</style>
