---
import { getCollection } from "astro:content";
import { ClientRouter } from "astro:transitions";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";

const posts = await getCollection("blog");

const tagCounts = posts.reduce(
  (acc, post) => {
    if (post.data.tags) {
      post.data.tags.forEach((tag) => {
        acc[tag] = (acc[tag] || 0) + 1;
      });
    }
    return acc;
  },
  {} as Record<string, number>,
);

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Tags — ${SITE_TITLE}`}
      description="Browse posts by tag."
    />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main>
      <div class="search-row">
        <h1 class="page-title">Tags</h1>
        <input
          type="search"
          id="tag-search"
          placeholder="Filter tags..."
          autocomplete="off"
        />
      </div>
      <p id="no-results" style="display:none" class="no-results">
        No tags match your search.
      </p>
      <ul class="tag-list" id="tag-list">
        {
          tags.map(([tag, count]) => (
            <li data-tag={tag.toLowerCase()}>
              <a href={`/tags/${tag}`} class="tag-item">
                <span class="tag-name">{tag}</span>
                <span class="tag-count">
                  {count} {count === 1 ? "post" : "posts"}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>

<script>
  function initTagSearch() {
    const input = document.getElementById("tag-search") as HTMLInputElement;
    const list = document.getElementById("tag-list");
    const noResults = document.getElementById("no-results");
    if (!input || !list || !noResults) return;

    input.addEventListener("input", () => {
      const query = input.value.toLowerCase().trim();
      const items = list.querySelectorAll<HTMLElement>("li");
      let visible = 0;

      items.forEach((item) => {
        const tag = item.dataset.tag ?? "";
        const matches = !query || tag.includes(query);
        item.style.display = matches ? "" : "none";
        if (matches) visible++;
      });

      noResults.style.display = visible === 0 ? "block" : "none";
    });
  }

  initTagSearch();
  document.addEventListener("astro:after-swap", initTagSearch);
</script>

<style>
  body {
    background: var(--posts-bg); /* or --projects-bg */
  }
  main {
    padding-bottom: 2em;
  }
  .search-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1em;
    margin-bottom: 1.5em;
    flex-wrap: wrap;
  }
  .page-title {
    font-size: 0.85em;
    color: var(--text-muted);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }
  #tag-search {
    font-size: 0.9em;
    padding: 0.4em 0.75em;
    border-radius: 6px;
    border: 0.5px solid var(--border);
    background: var(--bg-surface);
    color: var(--text);
    width: 220px;
    outline: none;
  }
  #tag-search:focus {
    border-color: var(--accent);
  }
  .no-results {
    color: var(--text-muted);
    font-size: 0.9em;
    padding: 1em 0;
  }
  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75em;
  }
  .tag-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.4em 1em;
    text-decoration: none;
    color: var(--text);
    background: var(--bg-subtle);
    border-radius: 6px;
    border: 0.5px solid var(--border);
    transition:
      background 0.15s,
      color 0.15s;
  }
  .tag-item:hover {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }
  .tag-item:hover .tag-count {
    color: var(--bg);
  }
  .tag-name {
    font-size: 0.95em;
  }
  .tag-count {
    font-size: 0.75em;
    color: var(--text-muted);
  }
</style>
