---
import { ClientRouter } from "astro:transitions";
import BaseHead from "../components/BaseHead.astro";
import CloudinaryImage from "../components/CloudinaryImage.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`About — ${SITE_TITLE}`}
      description="A little bit about Michael Baker."
    />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main>
      <div class="about-hero">
        <div class="about-hero-inner">
          <div class="about-hero-image">
            <CloudinaryImage
              publicId="photo-1617565084799-c4c60ea9ad7a_yvu0ps"
              alt="About Michael Baker"
              width={800}
              bare={true}
            />
          </div>
          <div class="about-hero-text">
            <div class="inner">
              <h1>About Me</h1>
              <p>
                I'm Michael. I build web products, tools, and publishing systems
                — and I write about them here. The projects range from practical
                utilities to platform experiments, but the common thread is
                turning messy or scattered information into something more
                useful and navigable.
              </p>
              <p>
                Recent work includes a local music discovery tool that treats
                concert listings as a review workflow, a link-in-bio publishing
                platform, a learning platform experiment with rich lesson
                authoring, and a fantasy sports dashboard that turned a
                spreadsheet into a shared interface. The work spans frontend,
                backend, deployment, and content systems.
              </p>
              <p>
                I have a background in online art education, which shapes how I
                think about interfaces: structure and expressiveness need to
                coexist, and the best tools disappear when they are working
                well.
              </p>
              <p>
                Posts here are project retrospectives rather than tutorials —
                what was built, what was difficult, what I would do differently.
                The best place to start is the <a href="/blog">blog</a>, the <a
                  href="/projects">projects</a
                > index, or browse by <a href="/tags">tag</a>.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="tools-section">
        <div class="inner">
          <h2>Tools and technologies</h2>
          <div class="tools-grid">
            <div class="tool-group">
              <h3>Frontend</h3>
              <div class="tool-tags">
                {
                  [
                    "React",
                    "Next.js",
                    "Astro",
                    "JavaScript",
                    "TypeScript",
                    "HTML",
                    "CSS",
                    "Tailwind",
                  ].map((tool) => <span class="tool-tag">{tool}</span>)
                }
              </div>
            </div>
            <div class="tool-group">
              <h3>Backend and data</h3>
              <div class="tool-tags">
                {
                  [
                    "Python",
                    "Flask",
                    "Node.js",
                    "Supabase",
                    "SQLite",
                    "PostgreSQL",
                  ].map((tool) => <span class="tool-tag">{tool}</span>)
                }
              </div>
            </div>
            <div class="tool-group">
              <h3>Content and authoring</h3>
              <div class="tool-tags">
                {
                  ["MDX", "Tiptap", "KaTeX", "Cloudinary"].map((tool) => (
                    <span class="tool-tag">{tool}</span>
                  ))
                }
              </div>
            </div>
            <div class="tool-group">
              <h3>Creative coding</h3>
              <div class="tool-tags">
                {
                  ["p5.js", "Strudel", "Mafs"].map((tool) => (
                    <span class="tool-tag">{tool}</span>
                  ))
                }
              </div>
            </div>
            <div class="tool-group">
              <h3>Design and no-code</h3>
              <div class="tool-tags">
                {
                  ["Figma", "Webflow", "Framer"].map((tool) => (
                    <span class="tool-tag">{tool}</span>
                  ))
                }
              </div>
            </div>
            <div class="tool-group">
              <h3>Deployment</h3>
              <div class="tool-tags">
                {
                  ["Vercel", "Railway", "GitHub Actions", "GitHub Pages"].map(
                    (tool) => <span class="tool-tag">{tool}</span>,
                  )
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    padding: 0;
  }
  .about-hero {
    background: var(--bg);
  }
  .about-hero-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    min-height: 500px;
    width: 100%;
    background: var(--hero-bg);
    overflow: hidden;
  }
  .about-hero-image {
    overflow: hidden;
  }
  .about-hero-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
    border: none;
  }
  .about-hero-text {
    padding: 3em;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--hero-bg);
  }
  .about-hero-text .inner {
    max-width: 480px;
    width: 100%;
  }
  .about-hero-text h1 {
    font-size: 2em;
    margin: 0 0 0.5em;
    color: var(--text);
    font-family: var(--font-syne);
  }
  .about-hero-text p {
    font-size: 0.9em;
    color: var(--text);
    line-height: 1.7;
    margin: 0 0 0.75em;
  }
  .about-hero-text a {
    color: var(--accent);
  }
  .tools-section {
    background: var(--bg);
  }
  .tools-section .inner {
    background: var(--projects-bg);
    width: 100%;
    padding: 3em;
    box-sizing: border-box;
  }
  .tools-section h2 {
    font-size: 0.85em;
    color: var(--text-muted);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 1.5em;
    font-family: var(--font-syne);
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2em;
    width: 100%;
  }
  .tool-group h3 {
    font-size: 0.85em;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 0.75em;
  }
  .tool-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
  }
  .tool-tag {
    background: var(--bg-surface);
    color: var(--text-muted);
    padding: 3px 10px;
    border-radius: 6px;
    font-size: 0.8em;
    border: 0.5px solid var(--border);
  }
  @media (max-width: 720px) {
    .about-hero-inner {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      max-width: 100%;
    }
    .about-hero-image {
      height: 250px;
      grid-row: 1;
    }
    .about-hero-text {
      grid-row: 2;
      padding: 2em 1.5em;
    }
    .tools-section .inner {
      max-width: 100%;
      padding: 2em 1.5em;
    }
  }
</style>
